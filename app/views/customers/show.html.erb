<header class="app-header">
  <div class="header-left">
    <%= link_to '＜ 戻る', customers_path, class: "btn-back" %>
  </div>
  
  <h1 class="header-title"><%= @customer.name %> さん</h1>
  
  <div class="header-right">
    <%= link_to '編集', edit_customer_path(@customer), class: "btn-edit" %>
  </div>
</header>

<main class="customer-detail">
  <section class="detail-info-card">
    <p>🎂 生年月日: <%= @customer.birth_date %> </p>
    <p>💼 加入商品: <%= @customer.product %></p>
    <div class="tags">
      <span class="badge status-active"><%= @customer.status %></span>
    </div>
  </section>

  <section class="timeline">
    <h3 class="timeline-title">商談・メモ履歴</h3>
    
    <% @customer.memos.each do |memo| %>
      <% if memo.persisted? %> <div class="memo-bubble">
          <p class="memo-date"><%= memo.created_at.strftime("%Y/%m/%d %H:%M") %></p>
          <p class="memo-text"><%= memo.content %></p>
        </div>
      <% end %>
    <% end %>
  </section>
</main>

<%= form_with(model: [@customer, Memo.new], class: "memo-input-area", local: true) do |form| %>
  <%= form.text_area :content, placeholder: "今日の商談メモを入力...", rows: 2 %>
  <%= form.submit "送信", class: "btn-send" %>
<% end %>